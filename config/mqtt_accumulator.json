{
  "name": "mqtt-accumulator",
  "sources": [
    {
      "name": "main",
      "broker": "tcp://localhost:1883",
      "topics": ["mqttdemo/#"]
    }
  ],
  "destination": {
    "broker": "tcp://localhost:1883"
  },
  "sub-processor": {
    "name": "processor-1",
    "keys" : [
      {
        "name": "device",
        "index": 0
      }
    ],
    "filters": ["motor"],
    "timeout": "10s",
    "destination": {
      "name": "processor-1-dest",
      "topic": "accumulated/{{._source}}/{{.device}}"
    },
    "pipeline": [
      "print",
      {
        "name": "render",
        "config": {
          "template": "Device {{.device}} - received {{len .payloads}} messages",
          "output": "summary"
        }
      },
      {
        "name": "render",
        "config": {
          "template_file": "config/templates/alert.tmpl",
          "output": "alert"
        }
      }
    ]
  }
}
