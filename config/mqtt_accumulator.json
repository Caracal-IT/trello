{
  "name": "mqtt-accumulator",
  "broker": "tcp://localhost:1883",
  "topics": ["mqttdemo/#"],
  "sub-processor": {
    "name": "processor-1",
    "keys" : [
      {
        "name": "device",
        "index": 0
      }
    ],
    "filters": ["motor"],
    "timeout": "10s",
    "pipeline": [
      "print",
      {
        "name": "render",
        "config": {
          "template": "Device {{.device}} - received {{len .payloads}} messages",
          "output": "summary"
        }
      },
      {
        "name": "render",
        "config": {
          "template_file": "config/templates/alert.tmpl",
          "output": "alert"
        }
      }
    ]
  }
}
